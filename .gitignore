# ============================================================
# .gitignore — Bioinfo (repositório multi-projeto)
# ============================================================

# --- R ---
.Rhistory
.RData
.Rproj.user/
.Ruserdata
*.Rout
*.Rcheck/
renv/library/
renv/staging/

# --- Sistema operacional ---
.DS_Store
Thumbs.db
desktop.ini

# --- Editores ---
.vscode/
.idea/
*.swp
*~

# --- Logs e temporários ---
*.log
*.tmp
*.temp
Temp/
tmp/

# --- Projeto legado (fora de escopo do pipeline ChIP-seq atual) ---
DiretorioR/

# --- XPC_metaChIP / ChIP-seq pipeline: dados brutos grandes, nunca versionados ---
# (a pasta em si permanece versionada via .gitkeep; só o conteúdo é ignorado)
XPC_metaChIP/Dados/FASTQ/*
!XPC_metaChIP/Dados/FASTQ/.gitkeep
XPC_metaChIP/Dados/BAM/*
!XPC_metaChIP/Dados/BAM/.gitkeep
XPC_metaChIP/Dados/BigWig/*
!XPC_metaChIP/Dados/BigWig/.gitkeep
XPC_metaChIP/Dados/GEO/*.sra
XPC_metaChIP/Dados/GEO/*.fastq.gz
XPC_metaChIP/Dados/GEO/*.fastq
XPC_metaChIP/Arquivos/**/*.bam
XPC_metaChIP/Arquivos/**/*.bam.bai
XPC_metaChIP/Arquivos/**/*.fastq.gz

# Genoma/índices reconstruíveis a partir do BSgenome instalado
XPC_metaChIP/Arquivos/genome_index/

# Genoma de referencia hg38 baixado (UCSC) e indice Bowtie2 construido a
# partir dele -- grandes (~8GB) e 100% reconstruiveis via build_hg38_index
XPC_metaChIP/Arquivos/genome/hg38.fa
XPC_metaChIP/Arquivos/genome/hg38.fa.gz
XPC_metaChIP/Arquivos/genome/hg38_bowtie2_index/

# Saidas de analise real regeneraveis a partir dos modulos (QC, alinhamento,
# filtragem, etc.) -- nao versionadas para nao inflar o repo a cada rodada
XPC_metaChIP/Arquivos/qc/
XPC_metaChIP/Arquivos/alignment/
XPC_metaChIP/Arquivos/filtering/
XPC_metaChIP/Arquivos/chip_qc/
XPC_metaChIP/Figuras/chip_qc/
XPC_metaChIP/Arquivos/differential/
XPC_metaChIP/Arquivos/peakcalling/
XPC_metaChIP/Dados/Peaks/

# Artefato deixado pelo pacote Rbowtie2 no diretório de trabalho (log de
# stderr do bowtie2, sempre regenerado a cada alinhamento)
.bowtie2.cerr.txt

# Logs/sessionInfo são regenerados a cada execução -- não versionados
# (a pasta em si permanece versionada via .gitkeep)
XPC_metaChIP/Logs/*
!XPC_metaChIP/Logs/.gitkeep

# Saidas da metanalise WT (regeneraveis a partir dos picos, 2026-07-18)
XPC_metaChIP/Arquivos/metanalise/
XPC_metaChIP/Arquivos/granges_hg38/
XPC_metaChIP/Arquivos/overlap/
XPC_metaChIP/Arquivos/hotspots/
XPC_metaChIP/Arquivos/network/
XPC_metaChIP/Arquivos/regulatory_universe.*
XPC_metaChIP/Arquivos/annotation/
XPC_metaChIP/Figuras/metanalise/
XPC_metaChIP/Figuras/annotation/
XPC_metaChIP/Dados/Metadata/occupancy_matrix.csv
XPC_metaChIP/Figuras/network/
XPC_metaChIP/Figuras/overlap/
XPC_metaChIP/Arquivos/enrichment/
XPC_metaChIP/Figuras/enrichment/
