# ============================================================
# .gitignore — Bioinfo (repositório multi-projeto)
# ============================================================

# --- R ---
.Rhistory
.RData
.Rproj.user/
.Ruserdata
*.Rout
*.Rcheck/
renv/library/
renv/staging/

# --- Sistema operacional ---
.DS_Store
Thumbs.db
desktop.ini

# --- Editores ---
.vscode/
.idea/
*.swp
*~

# --- Logs e temporários ---
*.log
*.tmp
*.temp
Temp/
tmp/

# --- Projeto legado (fora de escopo do pipeline ChIP-seq atual) ---
DiretorioR/

# --- ProjetosCode / ChIP-seq pipeline: dados brutos grandes, nunca versionados ---
# (a pasta em si permanece versionada via .gitkeep; só o conteúdo é ignorado)
ProjetosCode/Dados/FASTQ/*
!ProjetosCode/Dados/FASTQ/.gitkeep
ProjetosCode/Dados/BAM/*
!ProjetosCode/Dados/BAM/.gitkeep
ProjetosCode/Dados/BigWig/*
!ProjetosCode/Dados/BigWig/.gitkeep
ProjetosCode/Dados/GEO/*.sra
ProjetosCode/Dados/GEO/*.fastq.gz
ProjetosCode/Dados/GEO/*.fastq
ProjetosCode/Arquivos/**/*.bam
ProjetosCode/Arquivos/**/*.bam.bai
ProjetosCode/Arquivos/**/*.fastq.gz

# Genoma/índices reconstruíveis a partir do BSgenome instalado
ProjetosCode/Arquivos/genome_index/

# Genoma de referencia hg38 baixado (UCSC) e indice Bowtie2 construido a
# partir dele -- grandes (~8GB) e 100% reconstruiveis via build_hg38_index
ProjetosCode/Arquivos/genome/hg38.fa
ProjetosCode/Arquivos/genome/hg38.fa.gz
ProjetosCode/Arquivos/genome/hg38_bowtie2_index/

# Saidas de analise real regeneraveis a partir dos modulos (QC, alinhamento,
# filtragem, etc.) -- nao versionadas para nao inflar o repo a cada rodada
ProjetosCode/Arquivos/qc/
ProjetosCode/Arquivos/alignment/
ProjetosCode/Arquivos/filtering/
ProjetosCode/Arquivos/chip_qc/
ProjetosCode/Figuras/chip_qc/
ProjetosCode/Arquivos/differential/
ProjetosCode/Arquivos/peakcalling/
ProjetosCode/Dados/Peaks/

# Artefato deixado pelo pacote Rbowtie2 no diretório de trabalho (log de
# stderr do bowtie2, sempre regenerado a cada alinhamento)
.bowtie2.cerr.txt

# Logs/sessionInfo são regenerados a cada execução -- não versionados
# (a pasta em si permanece versionada via .gitkeep)
ProjetosCode/Logs/*
!ProjetosCode/Logs/.gitkeep

# Saidas da metanalise WT (regeneraveis a partir dos picos, 2026-07-18)
ProjetosCode/Arquivos/metanalise/
ProjetosCode/Arquivos/granges_hg38/
ProjetosCode/Arquivos/overlap/
ProjetosCode/Arquivos/hotspots/
ProjetosCode/Arquivos/network/
ProjetosCode/Arquivos/regulatory_universe.*
ProjetosCode/Arquivos/annotation/
ProjetosCode/Figuras/metanalise/
ProjetosCode/Figuras/annotation/
ProjetosCode/Dados/Metadata/occupancy_matrix.csv
ProjetosCode/Figuras/network/
ProjetosCode/Figuras/overlap/
ProjetosCode/Arquivos/enrichment/
ProjetosCode/Figuras/enrichment/
